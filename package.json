{
  "name": "moodlab",
  "version": "0.1.0",
  "private": true,
  "description": "MoodLab — creator-first LUT photo editor and platform API",
  "scripts": {
    "dev": "pnpm run --parallel dev:api dev:mobile",
    "dev:mobile": "pnpm --filter @moodlab/mobile start",
    "dev:api": "pnpm --filter @moodlab/api dev",
    "android": "pnpm --filter @moodlab/mobile android",
    "ios": "pnpm --filter @moodlab/mobile ios",
    "web": "pnpm --filter @moodlab/mobile web",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "lut:generate": "tsx tools/lut-studio/generate.ts",
    "lut:validate": "tsx tools/lut-studio/validate.ts",
    "lut:sync-catalog": "tsx tools/lut-studio/sync-catalog.ts",
    "lut:analyze": "tsx tools/lut-studio/analyze.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "yaml": "^2.7.0"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
